#!/bin/bash
# Molten tmux shim — intercepts tmux commands from Claude Code
# and translates them to Molten API calls.

MOLTEN_API="http://127.0.0.1:9900"
STATE_DIR="${TMPDIR:-/tmp}/molten-tmux"
PANE_MAP="$STATE_DIR/pane_map"       # pane_id=session_index
COUNTER_FILE="$STATE_DIR/pane_counter"
ACTIVE_FILE="$STATE_DIR/active_pane"

mkdir -p "$STATE_DIR"

[ -f "$COUNTER_FILE" ] || echo "0" > "$COUNTER_FILE"
[ -f "$ACTIVE_FILE" ] || echo "%0" > "$ACTIVE_FILE"
[ -f "$PANE_MAP" ] || echo "%0=1" > "$PANE_MAP"

# ── Helpers ──

next_pane_id() {
  local c=$(cat "$COUNTER_FILE" 2>/dev/null || echo 0)
  c=$((c + 1))
  echo "$c" > "$COUNTER_FILE"
  echo "%${c}"
}

get_active_pane() {
  cat "$ACTIVE_FILE" 2>/dev/null || echo "%0"
}

# Get absolute session index for a pane ID
pane_to_index() {
  local pane="$1"
  local idx
  idx=$(grep "^${pane}=" "$PANE_MAP" 2>/dev/null | head -1 | cut -d= -f2)
  echo "${idx:-1}"
}

# Register pane with its absolute session index
register_pane() {
  local pane_id="$1"
  local session_idx="$2"
  echo "${pane_id}=${session_idx}" >> "$PANE_MAP"
}

# Get current session count from Molten API
get_session_count() {
  local resp
  resp=$(curl -s "${MOLTEN_API}/api/session/count" 2>/dev/null)
  echo "$resp" | grep -o '"count":[0-9]*' | grep -o '[0-9]*' || echo "1"
}

urlencode() {
  local str="$1" encoded="" i c
  for ((i = 0; i < ${#str}; i++)); do
    c="${str:$i:1}"
    case "$c" in
      [a-zA-Z0-9.~_/-]) encoded+="$c" ;;
      ' ') encoded+="%20" ;;
      *) encoded+=$(printf '%%%02X' "'$c") ;;
    esac
  done
  echo "$encoded"
}

api() { curl -s "${MOLTEN_API}/api/$1" 2>/dev/null; }

# ── Parse args ──

CMD=""
ARGS=()

while [ $# -gt 0 ]; do
  case "$1" in
    -L) shift 2 ;;
    -f) shift 2 ;;
    *)
      if [ -z "$CMD" ]; then CMD="$1"; else ARGS+=("$1"); fi
      shift ;;
  esac
done

get_opt() {
  local flag="$1" i
  for ((i = 0; i < ${#ARGS[@]}; i++)); do
    [ "${ARGS[$i]}" = "$flag" ] && echo "${ARGS[$((i + 1))]}" && return 0
  done
  return 1
}

has_flag() {
  for arg in "${ARGS[@]}"; do [ "$arg" = "$1" ] && return 0; done
  return 1
}

# ── Commands ──

case "$CMD" in

  -V) echo "tmux 3.4" ;;

  has-session) exit 0 ;;

  new-session)
    # Get current count BEFORE creating
    COUNT=$(get_session_count)
    api "session/create" > /dev/null
    sleep 0.3
    NEW_IDX=$((COUNT + 1))
    PANE_ID=$(next_pane_id)
    register_pane "$PANE_ID" "$NEW_IDX"
    echo "$PANE_ID" > "$ACTIVE_FILE"
    has_flag "-P" && echo "$PANE_ID"
    ;;

  new-window)
    COUNT=$(get_session_count)
    api "session/create" > /dev/null
    sleep 0.3
    NEW_IDX=$((COUNT + 1))
    PANE_ID=$(next_pane_id)
    register_pane "$PANE_ID" "$NEW_IDX"
    has_flag "-P" && echo "$PANE_ID"
    ;;

  split-window)
    DIR="horizontal"
    has_flag "-v" && DIR="vertical"
    has_flag "-h" && DIR="horizontal"

    COUNT=$(get_session_count)
    api "split/$DIR" > /dev/null
    sleep 0.3
    NEW_IDX=$((COUNT + 1))
    PANE_ID=$(next_pane_id)
    register_pane "$PANE_ID" "$NEW_IDX"
    has_flag "-P" && echo "$PANE_ID"
    ;;

  send-keys)
    TARGET=$(get_opt "-t")
    TEXT=""
    SEND_ENTER=false

    for ((i = 0; i < ${#ARGS[@]}; i++)); do
      arg="${ARGS[$i]}"
      case "$arg" in
        -t) ((i++)) ;;
        Enter) SEND_ENTER=true ;;
        C-c|C-d|C-l) ;;
        *) [ -n "$TEXT" ] && TEXT+=" "; TEXT+="$arg" ;;
      esac
    done

    if [ -n "$TEXT" ]; then
      # Switch to correct session
      if [ -n "$TARGET" ]; then
        TPANE=$(echo "$TARGET" | grep -o '%[0-9]*' || echo "$TARGET")
        if [ -n "$TPANE" ]; then
          IDX=$(pane_to_index "$TPANE")
          api "session/switch/$IDX" > /dev/null
          sleep 0.15
        fi
      fi

      ENCODED=$(urlencode "$TEXT")
      api "session/type/$ENCODED" > /dev/null
    fi
    ;;

  select-pane)
    TARGET=$(get_opt "-t")
    if [ -n "$TARGET" ]; then
      TPANE=$(echo "$TARGET" | grep -o '%[0-9]*' || echo "$TARGET")
      if [ -n "$TPANE" ]; then
        echo "$TPANE" > "$ACTIVE_FILE"
        IDX=$(pane_to_index "$TPANE")
        api "session/switch/$IDX" > /dev/null
      fi
    fi
    ;;

  display-message)
    FMT=$(get_opt "-p")
    CURRENT=$(get_active_pane)
    case "$FMT" in
      *pane_id*) echo "$CURRENT" ;;
      *session_name*window_index*) echo "molten:0" ;;
      *session_name*) echo "molten" ;;
      *window_index*) echo "0" ;;
      *) echo "$CURRENT" ;;
    esac
    ;;

  list-panes)
    cut -d= -f1 "$PANE_MAP" 2>/dev/null || echo "%0"
    ;;

  list-windows) echo "swarm-view" ;;

  list-sessions) echo "molten: 1 windows (created $(date))" ;;

  kill-pane)
    TARGET=$(get_opt "-t")
    if [ -n "$TARGET" ]; then
      TPANE=$(echo "$TARGET" | grep -o '%[0-9]*' || echo "$TARGET")
      IDX=$(pane_to_index "$TPANE")
      api "session/switch/$IDX" > /dev/null
      sleep 0.1
      api "session/close" > /dev/null
      grep -v "^${TPANE}=" "$PANE_MAP" > "$PANE_MAP.tmp" 2>/dev/null
      mv "$PANE_MAP.tmp" "$PANE_MAP" 2>/dev/null
    fi
    ;;

  kill-session|kill-server) ;;
  set-option|set) ;;
  select-layout) ;;
  resize-pane) ;;
  break-pane|join-pane) ;;
  load-buffer) ;;
  *) ;;

esac

exit 0

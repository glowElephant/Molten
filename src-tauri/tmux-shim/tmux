#!/bin/bash
# Molten tmux shim — intercepts tmux commands from Claude Code
# and translates them to Molten API calls.
# Uses actual PTY session IDs for reliable targeting.

MOLTEN_API="http://127.0.0.1:9900"
STATE_DIR="${TMPDIR:-/tmp}/molten-tmux"
PANE_MAP="$STATE_DIR/pane_map"       # pane_id=pty_session_id
COUNTER_FILE="$STATE_DIR/pane_counter"
ACTIVE_FILE="$STATE_DIR/active_pane"
LOG_FILE="$STATE_DIR/shim.log"

mkdir -p "$STATE_DIR"

[ -f "$COUNTER_FILE" ] || echo "0" > "$COUNTER_FILE"
[ -f "$ACTIVE_FILE" ] || echo "%0" > "$ACTIVE_FILE"

# On first run, map %0 to the current session
if [ ! -f "$PANE_MAP" ]; then
  # Get the list of current PTY session IDs
  SESSIONS=$(curl -s "${MOLTEN_API}/api/sessions" 2>/dev/null)
  # Extract first session ID (the one running Claude Code)
  FIRST_ID=$(echo "$SESSIONS" | grep -o '"[^"]*"' | head -1 | tr -d '"')
  if [ -n "$FIRST_ID" ]; then
    echo "%0=$FIRST_ID" > "$PANE_MAP"
  else
    echo "%0=unknown" > "$PANE_MAP"
  fi
fi

log() {
  echo "[$(date +%H:%M:%S)] $*" >> "$LOG_FILE"
}

# ── Helpers ──

next_pane_id() {
  local c=$(cat "$COUNTER_FILE" 2>/dev/null || echo 0)
  c=$((c + 1))
  echo "$c" > "$COUNTER_FILE"
  echo "%${c}"
}

get_active_pane() {
  cat "$ACTIVE_FILE" 2>/dev/null || echo "%0"
}

# Get actual PTY session ID for a pane
pane_to_session_id() {
  local pane="$1"
  local sid
  sid=$(grep "^${pane}=" "$PANE_MAP" 2>/dev/null | head -1 | cut -d= -f2)
  echo "$sid"
}

# Register pane with its actual PTY session ID
register_pane() {
  local pane_id="$1"
  local session_id="$2"
  echo "${pane_id}=${session_id}" >> "$PANE_MAP"
  log "Registered pane $pane_id -> session $session_id"
}

# Get the newest session ID (the one just created)
get_newest_session() {
  local before="$1"
  local after
  after=$(curl -s "${MOLTEN_API}/api/sessions" 2>/dev/null)
  # Find IDs in after that weren't in before
  for id in $(echo "$after" | grep -o '"[^"]*"' | tr -d '"'); do
    if ! echo "$before" | grep -q "$id"; then
      echo "$id"
      return
    fi
  done
  # Fallback: return last ID
  echo "$after" | grep -o '"[^"]*"' | tail -1 | tr -d '"'
}

urlencode() {
  local str="$1" encoded="" i c
  for ((i = 0; i < ${#str}; i++)); do
    c="${str:$i:1}"
    case "$c" in
      [a-zA-Z0-9.~_/-]) encoded+="$c" ;;
      ' ') encoded+="%20" ;;
      *) encoded+=$(printf '%%%02X' "'$c") ;;
    esac
  done
  echo "$encoded"
}

api() { curl -s "${MOLTEN_API}/api/$1" 2>/dev/null; }

# ── Parse args ──

CMD=""
ARGS=()

while [ $# -gt 0 ]; do
  case "$1" in
    -L) shift 2 ;;
    -f) shift 2 ;;
    *)
      if [ -z "$CMD" ]; then CMD="$1"; else ARGS+=("$1"); fi
      shift ;;
  esac
done

log "CMD=$CMD ARGS=${ARGS[*]}"

get_opt() {
  local flag="$1" i
  for ((i = 0; i < ${#ARGS[@]}; i++)); do
    [ "${ARGS[$i]}" = "$flag" ] && echo "${ARGS[$((i + 1))]}" && return 0
  done
  return 1
}

has_flag() {
  for arg in "${ARGS[@]}"; do [ "$arg" = "$1" ] && return 0; done
  return 1
}

# ── Commands ──

case "$CMD" in

  -V) echo "tmux 3.4" ;;

  has-session) exit 0 ;;

  new-session)
    BEFORE=$(curl -s "${MOLTEN_API}/api/sessions" 2>/dev/null)
    api "session/create" > /dev/null
    sleep 0.8
    NEW_SID=$(get_newest_session "$BEFORE")
    PANE_ID=$(next_pane_id)
    register_pane "$PANE_ID" "$NEW_SID"
    echo "$PANE_ID" > "$ACTIVE_FILE"
    has_flag "-P" && echo "$PANE_ID"
    ;;

  new-window)
    BEFORE=$(curl -s "${MOLTEN_API}/api/sessions" 2>/dev/null)
    api "session/create" > /dev/null
    sleep 0.8
    NEW_SID=$(get_newest_session "$BEFORE")
    PANE_ID=$(next_pane_id)
    register_pane "$PANE_ID" "$NEW_SID"
    has_flag "-P" && echo "$PANE_ID"
    ;;

  split-window)
    DIR="horizontal"
    has_flag "-v" && DIR="vertical"
    has_flag "-h" && DIR="horizontal"

    BEFORE=$(curl -s "${MOLTEN_API}/api/sessions" 2>/dev/null)
    api "split/$DIR" > /dev/null
    sleep 0.8
    NEW_SID=$(get_newest_session "$BEFORE")
    PANE_ID=$(next_pane_id)
    register_pane "$PANE_ID" "$NEW_SID"
    has_flag "-P" && echo "$PANE_ID"
    ;;

  send-keys)
    TARGET=$(get_opt "-t")
    TEXT=""
    SEND_ENTER=false

    for ((i = 0; i < ${#ARGS[@]}; i++)); do
      arg="${ARGS[$i]}"
      case "$arg" in
        -t) ((i++)) ;;
        Enter) SEND_ENTER=true ;;
        C-c|C-d|C-l) ;;
        *) [ -n "$TEXT" ] && TEXT+=" "; TEXT+="$arg" ;;
      esac
    done

    if [ -n "$TEXT" ]; then
      # Determine target session ID
      SID=""
      if [ -n "$TARGET" ]; then
        TPANE=$(echo "$TARGET" | grep -o '%[0-9]*' || echo "$TARGET")
        SID=$(pane_to_session_id "$TPANE")
      fi

      if [ -n "$SID" ] && [ "$SID" != "unknown" ]; then
        # Write directly to PTY — no switching needed
        ENCODED=$(urlencode "$TEXT")
        log "send-keys to pane=$TPANE sid=$SID text=$TEXT"
        api "pty/write/$SID/$ENCODED" > /dev/null
      else
        # Fallback: type into active session via eval_js
        ENCODED=$(urlencode "$TEXT")
        log "send-keys fallback text=$TEXT"
        api "session/type/$ENCODED" > /dev/null
      fi
    fi
    ;;

  select-pane)
    TARGET=$(get_opt "-t")
    if [ -n "$TARGET" ]; then
      TPANE=$(echo "$TARGET" | grep -o '%[0-9]*' || echo "$TARGET")
      if [ -n "$TPANE" ]; then
        echo "$TPANE" > "$ACTIVE_FILE"
        SID=$(pane_to_session_id "$TPANE")
        if [ -n "$SID" ] && [ "$SID" != "unknown" ]; then
          # Find session index for UI switching
          SESSIONS=$(curl -s "${MOLTEN_API}/api/sessions" 2>/dev/null)
          IDX=1
          for id in $(echo "$SESSIONS" | grep -o '"[^"]*"' | tr -d '"'); do
            if [ "$id" = "$SID" ]; then
              api "session/switch/$IDX" > /dev/null
              break
            fi
            IDX=$((IDX + 1))
          done
        fi
      fi
    fi
    ;;

  display-message)
    FMT=$(get_opt "-p")
    CURRENT=$(get_active_pane)
    case "$FMT" in
      *pane_id*) echo "$CURRENT" ;;
      *session_name*window_index*) echo "molten:0" ;;
      *session_name*) echo "molten" ;;
      *window_index*) echo "0" ;;
      *) echo "$CURRENT" ;;
    esac
    ;;

  list-panes)
    cut -d= -f1 "$PANE_MAP" 2>/dev/null || echo "%0"
    ;;

  list-windows) echo "swarm-view" ;;

  list-sessions) echo "molten: 1 windows (created $(date))" ;;

  kill-pane)
    TARGET=$(get_opt "-t")
    if [ -n "$TARGET" ]; then
      TPANE=$(echo "$TARGET" | grep -o '%[0-9]*' || echo "$TARGET")
      SID=$(pane_to_session_id "$TPANE")
      if [ -n "$SID" ]; then
        # Switch to session and close it
        SESSIONS=$(curl -s "${MOLTEN_API}/api/sessions" 2>/dev/null)
        IDX=1
        for id in $(echo "$SESSIONS" | grep -o '"[^"]*"' | tr -d '"'); do
          if [ "$id" = "$SID" ]; then
            api "session/switch/$IDX" > /dev/null
            sleep 0.1
            api "session/close" > /dev/null
            break
          fi
          IDX=$((IDX + 1))
        done
      fi
      grep -v "^${TPANE}=" "$PANE_MAP" > "$PANE_MAP.tmp" 2>/dev/null
      mv "$PANE_MAP.tmp" "$PANE_MAP" 2>/dev/null
    fi
    ;;

  kill-session|kill-server) ;;
  set-option|set) ;;
  select-layout) ;;
  resize-pane) ;;
  break-pane|join-pane) ;;
  load-buffer) ;;
  *) ;;

esac

exit 0
